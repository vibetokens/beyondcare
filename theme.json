{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        {"slug":"teal","name":"Teal","color":"#1A7A87"},
        {"slug":"teal-dark","name":"Teal Dark","color":"#0D5059"},
        {"slug":"teal-deeper","name":"Teal Deeper","color":"#093840"},
        {"slug":"teal-light","name":"Teal Light","color":"#EAF5F7"},
        {"slug":"coral","name":"Coral","color":"#C94040"},
        {"slug":"coral-hover","name":"Coral Dark","color":"#A83232"},
        {"slug":"cream","name":"Cream","color":"#F8F4EE"},
        {"slug":"warm-white","name":"Warm White","color":"#FEFCF9"},
        {"slug":"charcoal","name":"Charcoal","color":"#1C2B2E"},
        {"slug":"mid","name":"Mid Grey","color":"#4A5F63"},
        {"slug":"sky","name":"Sky","color":"#4EC8E2"}
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Cormorant Garamond', serif",
          "slug": "cormorant",
          "name": "Cormorant Garamond"
        },
        {
          "fontFamily": "'DM Sans', sans-serif",
          "slug": "dm-sans",
          "name": "DM Sans"
        }
      ]
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "spacing": {
      "units": ["px", "%", "em", "rem", "vw", "vh"]
    }
  },
  "styles": {
    "color": {
      "background": "#FEFCF9",
      "text": "#1C2B2E"
    },
    "typography": {
      "fontFamily": "'DM Sans', sans-serif",
      "fontSize": "16px",
      "lineHeight": "1.65"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "'Cormorant Garamond', serif",
          "fontWeight": "500",
          "lineHeight": "1.15"
        }
      },
      "h1": { "typography": { "fontSize": "clamp(40px, 5vw, 64px)" } },
      "h2": { "typography": { "fontSize": "clamp(32px, 4vw, 48px)" } },
      "h3": { "typography": { "fontSize": "clamp(22px, 2.5vw, 30px)" } },
      "link": {
        "color": { "text": "#1A7A87" },
        ":hover": { "color": { "text": "#0D5059" } }
      },
      "button": {
        "color": { "background": "#C94040", "text": "#ffffff" },
        "typography": { "fontFamily": "'DM Sans', sans-serif", "fontWeight": "600" },
        "border": { "radius": "8px" }
      }
    }
  }
}

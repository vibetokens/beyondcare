# ── Notion (feedback widget) ──────────────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_FEEDBACK_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (form submissions via Resend) ───────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Email address that receives inquiry notifications
CONTACT_NOTIFY_EMAIL=info@beyondcarehc.com
# "From" address — must be a verified Resend domain
RESEND_FROM_EMAIL=noreply@beyondcarehc.com

# ── Analytics ─────────────────────────────────────────────────────────────
# PostHog (privacy-friendly analytics) — sign up at posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# PostHog server-side API (for monthly report) — Settings → Personal API Keys
POSTHOG_PERSONAL_API_KEY=phx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PostHog project ID — found in project Settings URL
POSTHOG_PROJECT_ID=12345

# ── Google Search Console ─────────────────────────────────────────────────
# Meta tag verification ID — from GSC Add Property flow
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_id_here
# GSC service account (for monthly report) — GCP → IAM → Service Accounts
GSC_CLIENT_EMAIL=beyondcare-reports@your-project.iam.gserviceaccount.com
# Paste the private_key from your service account JSON (keep the -----BEGIN/END----- lines)
GSC_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nxxx\n-----END RSA PRIVATE KEY-----"
GSC_SITE_URL=https://beyondcarehc.com

# ── Monthly Report ────────────────────────────────────────────────────────
# Secret for manually triggering: /api/monthly-report?force=true&secret=X
REPORT_SECRET=your_secret_here

# ── Client Portal ─────────────────────────────────────────────────────────
PORTAL_PASSWORD=your_portal_password_here

# ── Site ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://beyondcarehc.com
